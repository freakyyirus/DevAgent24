# DevAgent24 — Environment Variables Example
# Copy this file to .env.local and fill in your keys.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Groq ---
GROQ_API_KEY=your-groq-api-key

# --- Judge0 (RapidAPI) ---
JUDGE0_API_KEY=your-rapidapi-key
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com

# --- Solana ---
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PRIVATE_KEY=[1,2,3...] # Get from scripts/solana-setup.ts
SOLANA_PROGRAM_ID=your-deployed-program-id

# --- Optional ---
N8N_WEBHOOK_URL=your-n8n-webhook
PINATA_API_KEY=your-pinata-key
PINATA_SECRET_KEY=your-pinata-secret
